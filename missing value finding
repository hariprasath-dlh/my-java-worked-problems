import java.util.*;
public class Main{
	public static void main(String[] args) {
	    Scanner sc = new Scanner(System.in);
	    int s = sc.nextInt();
	    int[] arr = new int[s];
	    int sum = 0;
	    for(int i=0; i<s; i++){
	        arr[i] = sc.nextInt();
	        sum+=arr[i];
	    }
	    int n = s+1;
	    int out = n*(n+1) / 2;
	    int missing = out - sum;
	    System.out.println("Missing Number = " + missing);
	}
}
